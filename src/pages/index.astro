---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const skills = [
  'Ruby on Rails',
  'TypeScript',
  'React',
  'Elixir / Phoenix',
  'PostgreSQL',
  'AI / LLMs',
  'Stripe',
  'Sidekiq',
];
---

<Layout title="Ken Rettberg — Senior Full-Stack Engineer">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-20">
    <!-- Availability badge -->
    <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 dark:bg-emerald-900/20 dark:border-emerald-800 px-3 py-1.5 rounded-full mb-10">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      <span class="text-xs font-medium text-emerald-700 dark:text-emerald-400">Available for new roles</span>
    </div>

    <!-- Name -->
    <h1 class="text-[clamp(3.5rem,9vw,5.5rem)] font-extrabold tracking-tight text-[#1a1a1a] dark:text-white leading-[1.0] mb-6">
      <span class="text-mark">Ken</span><br />
      Rettberg
    </h1>

    <!-- Role -->
    <p class="text-lg text-gray-500 dark:text-gray-400 font-medium mb-5">
      Senior Full-Stack Engineer &amp; Culture Builder
    </p>

    <!-- Bio -->
    <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-10 max-w-xl font-normal">
      I build systems that hold up under real pressure — financial platforms, AI-powered search,
      developer tools people actually use. I believe in engineering empathy: code that works as
      well for the team maintaining it as it does for the end user.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center gap-3 mb-14">
      <a href="mailto:kenrettberg@gmail.com" class="btn-solid">
        Get in touch
      </a>
      <a href="#projects" class="btn-outline">
        See my work
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
    </div>

    <!-- Skills -->
    <div class="flex flex-wrap gap-2">
      {skills.map((skill, i) => (
        <span class={`tag-${i % 8} inline-block px-3 py-1.5 rounded-lg text-sm font-medium`}>
          {skill}
        </span>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section class="max-w-4xl mx-auto px-6 pb-20" id="projects">
    <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-8">Projects</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {sorted.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto px-6">
    <hr class="border-black/8 dark:border-white/8" />
  </div>

  <!-- Contact -->
  <section class="max-w-4xl mx-auto px-6 py-20" id="contact">
    <div class="max-w-xl">
      <h2 class="text-2xl font-bold text-[#1a1a1a] dark:text-gray-100 mb-3 tracking-tight">Let's talk</h2>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-8">
        I'm open to senior engineering roles and
        conversations about what you're building. Please reach out — I respond to every message.
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="mailto:kenrettberg@gmail.com" class="btn-solid">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Send an email
        </a>
        <a
          href="https://linkedin.com/in/kenrettberg"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>
</Layout>

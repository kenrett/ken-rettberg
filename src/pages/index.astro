---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);

const skills = [
  'Ruby on Rails',
  'TypeScript',
  'React',
  'Next.js',
  'PostgreSQL',
  'AI / LLMs',
  'Sidekiq',
];

const neonBadgeClasses = [
  'neon-badge-green',
  'neon-badge-cyan',
  'neon-badge-pink',
  'neon-badge-yellow',
  'neon-badge-purple',
  'neon-badge-orange',
];
---

<Layout title="Ken Rettberg — Senior Full-Stack Engineer">
  <!-- Hero -->
  <section class="relative w-full overflow-hidden">
    <!-- Cosmic Aura Background Splash -->
    <div class="absolute inset-0 pointer-events-none select-none z-0">
      <!-- Glow orbs (increased opacity for visibility under heavy blur) -->
      <div class="absolute top-[-10%] left-[10%] w-[500px] h-[500px] rounded-full bg-emerald-500/[0.15] filter blur-[120px] animate-float-1"></div>
      <div class="absolute top-[5%] right-[10%] w-[550px] h-[550px] rounded-full bg-purple-600/[0.18] filter blur-[130px] animate-float-2"></div>
      <div class="absolute top-[30%] left-[30%] w-[350px] h-[350px] rounded-full bg-cyan-500/[0.12] filter blur-[110px]"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-24">
      <!-- Availability badge -->
    <div class="inline-flex items-center gap-2 bg-[#121214] border border-[#27272a] px-3.5 py-1.5 rounded-full mb-10">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-wider">Open to new senior roles</span>
    </div>

    <!-- Name / Large Dev Header -->
    <h1 class="text-[clamp(3.5rem,8vw,5.5rem)] font-black tracking-tight text-white leading-[0.95] mb-6 uppercase">
      KEN RETTBERG
    </h1>

    <!-- Bio / Headline -->
    <p class="text-xl sm:text-2xl text-gray-300 font-mono tracking-tight mb-8 max-w-3xl leading-snug">
      I build systems that work under pressure and support the people making them.
    </p>

    <p class="text-base sm:text-lg text-gray-500 leading-relaxed mb-12 max-w-2xl font-normal">
      I'm a senior full-stack engineer who values straightforward architecture and engineering empathy. I spend most of my time writing clean Rails, React, and Next.js, aiming for code that's as clear to the team maintaining it as it is responsive for the end user.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center gap-4 mb-16">
      <a href="mailto:kenrettberg@gmail.com" class="btn-pill px-6 py-3">
        Say hello <span class="text-gray-500 font-mono">→</span>
      </a>
      <a href="#projects" class="text-xs font-mono uppercase tracking-wider text-gray-400 hover:text-white transition-colors py-3">
        Explore projects <span class="text-gray-600 font-mono">↓</span>
      </a>
    </div>

    <!-- Skills -->
    <div class="flex flex-wrap gap-2">
      {skills.map((skill, i) => (
        <span class={neonBadgeClasses[i % neonBadgeClasses.length]}>
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>

  <!-- Projects -->
  <section class="max-w-6xl mx-auto px-6 py-28 border-t border-[#27272a]" id="projects">
    <div class="text-center mb-16">
      <h2 class="text-xs font-mono uppercase tracking-[0.2em] text-neon-green mb-3">Portfolio</h2>
      <h3 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight">Featured Work</h3>
      <p class="text-sm text-gray-500 max-w-md mx-auto mt-2 font-mono">A few things I've built recently that I'm proud of.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="max-w-5xl mx-auto px-6 py-28 border-t border-[#27272a]" id="contact">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xs font-mono uppercase tracking-[0.2em] text-neon-green mb-3">Say Hello</h2>
      <h3 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight mb-4">Let's talk</h3>
      <p class="text-gray-500 leading-relaxed mb-10 font-mono text-sm">
        I'm looking for my next senior role, but I'm always up for discussing architecture or what you're working on. Reach out — I read and reply to every message.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:kenrettberg@gmail.com" class="btn-pill px-8 py-3">
          Send an email <span class="text-gray-500 font-mono">→</span>
        </a>
        <a
          href="https://linkedin.com/in/kenrettberg"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-pill px-8 py-3 bg-black hover:bg-[#18181b]"
        >
          LinkedIn <span class="text-gray-500 font-mono">↗</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

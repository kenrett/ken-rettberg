---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Ken Rettberg — Senior Full-Stack Engineer">
  <!-- Hero -->
  <section class="relative max-w-4xl mx-auto px-6 pt-24 pb-20 overflow-hidden">
    <!-- Subtle indigo glow -->
    <div class="absolute top-0 left-0 w-[600px] h-[400px] -translate-x-1/3 -translate-y-1/4 bg-indigo-500/10 dark:bg-indigo-500/8 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-2xl">
      <!-- Availability badge -->
      <div class="flex items-center gap-2 mb-10">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        <span class="text-sm text-gray-500 dark:text-gray-400">Available for new roles</span>
      </div>

      <!-- Name -->
      <h1 class="text-6xl sm:text-7xl font-bold tracking-tight text-gray-900 dark:text-white leading-[1.05] mb-5">
        Ken<br />Rettberg
      </h1>

      <!-- Role with accent line -->
      <p class="flex items-center gap-3 text-sm font-medium text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-8">
        <span class="h-px w-8 bg-indigo-500 dark:bg-indigo-400 shrink-0"></span>
        Senior Full-Stack Engineer & Culture Builder
      </p>

      <!-- Bio — tightened -->
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-10 max-w-xl">
        I build systems that hold up under real pressure — financial platforms, AI-powered search,
        developer tools people actually use. I believe in engineering empathy: code that works as
        well for the team maintaining it as it does for the end user.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="mailto:kenrettberg@gmail.com"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white font-medium text-sm transition-colors"
        >
          Get in touch
        </a>
        <a
          href="#projects"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
        >
          See my work
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="max-w-4xl mx-auto px-6 pb-20" id="projects">
    <div class="flex items-baseline gap-3 mb-8">
      <span class="h-px w-6 bg-gray-300 dark:bg-gray-700"></span>
      <h2 class="text-sm font-medium text-gray-500 dark:text-gray-500 uppercase tracking-widest">Projects</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {sorted.map(project => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto px-6">
    <hr class="border-gray-200 dark:border-gray-800" />
  </div>

  <!-- Contact -->
  <section class="max-w-4xl mx-auto px-6 py-20" id="contact">
    <div class="max-w-xl">
      <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Let's talk</h2>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
        I'm open to senior engineering roles and
        conversations about what you're building. Please reach out, I respond to every message!
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="mailto:kenrettberg@gmail.com"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white font-medium text-sm transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Send an email
        </a>
        <a
          href="https://linkedin.com/in/kenrettberg"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 hover:border-gray-400 dark:hover:border-gray-600 text-gray-700 dark:text-gray-300 font-medium text-sm transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>
</Layout>

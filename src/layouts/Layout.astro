---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Senior Full-Stack Engineer. I build systems that handle real-world pressure and support the people making them.",
} = Astro.props;

const GITHUB = 'https://github.com/kenrettberg';
const LINKEDIN = 'https://linkedin.com/in/kenrettberg';
const EMAIL = 'kenrettberg@gmail.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <script is:inline>
      document.documentElement.classList.add('dark');
    </script>
  </head>

  <body class="bg-black text-[#e4e4e7] antialiased selection:bg-neon-green/30 selection:text-white">
    <header class="border-b border-[#27272a] bg-black/85 backdrop-blur-md sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a href="/" class="font-extrabold text-white text-base tracking-tight hover:opacity-85 transition-opacity">
            KEN RETTBERG
          </a>
          <span class="hidden sm:inline text-xs text-gray-800 font-mono">|</span>
          <span class="hidden sm:inline text-xs text-gray-500 font-mono tracking-wider uppercase">Senior Full-Stack Engineer</span>
        </div>

        <div class="hidden sm:flex items-center gap-6">
          <a href="#projects" class="text-xs font-mono uppercase tracking-wider text-gray-400 hover:text-white transition-colors">Portfolio</a>
          <a href="#contact" class="text-xs font-mono uppercase tracking-wider text-gray-400 hover:text-white transition-colors">Contact</a>
        </div>

        <div class="flex items-center gap-3">
          <a href={`mailto:${EMAIL}`} class="btn-pill">
            Get in touch <span class="text-gray-500 font-mono">→</span>
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[#27272a] mt-24 bg-[#09090b]">
      <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-6 text-sm text-gray-500">
        <div class="flex flex-col items-center sm:items-start gap-1">
          <span class="font-extrabold text-white text-sm tracking-tight">KEN RETTBERG</span>
          <span class="text-xs text-gray-600">Senior Full-Stack Engineer</span>
        </div>
        <div class="flex items-center gap-6">
          <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub</a>
          <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LinkedIn</a>
          <a href={`mailto:${EMAIL}`} class="hover:text-white transition-colors">Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
